{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "jsx": "preserve",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "esModuleInterop": true,
        "lib": [
            "ESNext",
            "DOM"
        ],
        "skipLibCheck": true,
        "baseUrl": ".",
        "paths": {
            "vue": [
                "../../apps/configurator/node_modules/vue"
            ],
            "vue-i18n": [
                "../../apps/configurator/node_modules/vue-i18n"
            ],
            "@tauri-apps/api/*": [
                "../../apps/configurator/node_modules/@tauri-apps/api/*"
            ]
        }
    },
    "include": [
        "src/**/*.ts",
        "src/**/*.d.ts",
        "src/**/*.tsx",
        "src/**/*.vue"
    ]
}