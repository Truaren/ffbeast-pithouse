{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "FFBeast UI",
    "version": "1.0.0",
    "identifier": "br.com.sodevs.ffbeast-ui",
    "build": {
        "frontendDist": "../dist",
        "devUrl": "http://localhost:1420",
        "beforeDevCommand": "npm run dev",
        "beforeBuildCommand": "npm run build"
    },
    "app": {
        "withGlobalTauri": true,
        "windows": [
            {
                "title": "FFBeast UI",
                "width": 1000,
                "height": 750,
                "resizable": true,
                "center": true
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/64x64.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "publisher": "SODevs Sistemas",
        "copyright": "Copyright © 2026 SODevs Sistemas - contato@sodevs.com.br",
        "shortDescription": "FFBeast Force Feedback Controller Configuration Tool",
        "longDescription": "Professional configuration tool for FFBeast Force Feedback controllers by SODevs Sistemas"
    }
}