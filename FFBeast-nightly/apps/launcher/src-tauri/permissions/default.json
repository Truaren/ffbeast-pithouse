{
    "permission": [
        {
            "identifier": "allow-all-commands",
            "description": "Allows all custom commands",
            "commands": {
                "allow": [
                    "check_hardware",
                    "get_games",
                    "save_game",
                    "get_game",
                    "delete_game",
                    "reset_center",
                    "reboot_device",
                    "update_effect_settings",
                    "update_hardware_settings",
                    "get_effect_settings",
                    "get_hardware_settings",
                    "save_settings_to_hardware",
                    "open_advanced_config",
                    "launch_game",
                    "scan_steam_library",
                    "search_games",
                    "fetch_game_metadata",
                    "get_default_wheel_settings",
                    "save_default_wheel_settings",
                    "get_gamepad_mapping",
                    "save_gamepad_mapping",
                    "apply_wheel_settings_to_hardware",
                    "greet"
                ]
            }
        }
    ],
    "set": [
        {
            "identifier": "default",
            "description": "Default feature set",
            "permissions": [
                "allow-all-commands"
            ]
        }
    ]
